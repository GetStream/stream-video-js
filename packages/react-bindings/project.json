{
  "name": "@stream-io/video-react-bindings",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "dryRun": false,
        "baseBranch": "main",
        "preset": {
          "name": "conventionalcommits",
          "preMajor": false,
          "types": [
            { "type": "feat", "section": "Features" },
            { "type": "fix", "section": "Bug Fixes" },
            { "type": "chore", "section": "Chores" },
            { "type": "docs", "hidden": true },
            { "type": "style", "hidden": true },
            { "type": "refactor", "section": "Refactors" },
            { "type": "perf", "section": "Features" },
            { "type": "test", "hidden": true }
          ]
        },
        "trackDeps": true,
        "push": true,
        "skipCommitTypes": ["ci", "refactor", "test", "docs"],
        "postTargets": [
          "@stream-io/video-react-bindings:enrich-changelog",
          "@stream-io/video-react-bindings:github",
          "@stream-io/video-react-bindings:publish"
        ]
      }
    },
    "github": {
      "executor": "@jscutlery/semver:github",
      "options": {
        "tag": "${tag}",
        "notesFile": "packages/react-bindings/.release-notes.md"
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "yarn release:react-bindings",
            "forwardAllArgs": false
          }
        ]
      }
    },
    "enrich-changelog": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node scripts/release/enrich-dependency-changelogs.mts --package @stream-io/video-react-bindings --notes-out packages/react-bindings/.release-notes.md",
            "forwardAllArgs": false
          }
        ]
      }
    }
  }
}
