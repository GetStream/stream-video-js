{
  "name": "@stream-io/video-react-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "dryRun": false,
        "baseBranch": "main",
        "preset": {
          "name": "conventionalcommits",
          "preMajor": false,
          "types": [
            {
              "type": "feat",
              "section": "Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            },
            {
              "type": "chore",
              "section": "Chores"
            },
            {
              "type": "docs",
              "hidden": true
            },
            {
              "type": "style",
              "hidden": true
            },
            {
              "type": "refactor",
              "section": "Refactors"
            },
            {
              "type": "perf",
              "section": "Features"
            },
            {
              "type": "test",
              "hidden": true
            }
          ]
        },
        "trackDeps": true,
        "push": true,
        "skipCommitTypes": ["ci", "refactor", "test", "docs"],
        "postTargets": [
          "@stream-io/video-react-sdk:update-version",
          "@stream-io/video-react-sdk:enrich-changelog",
          "@stream-io/video-react-sdk:github",
          "@stream-io/video-react-sdk:publish",
          "@stream-io/video-react-sdk:deploy-sample-apps"
        ]
      }
    },
    "update-version": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "yarn build:react:sdk",
            "forwardAllArgs": false
          }
        ]
      }
    },
    "github": {
      "executor": "@jscutlery/semver:github",
      "options": {
        "tag": "${tag}",
        "notesFile": "packages/react-sdk/.release-notes.md"
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "yarn release:react-sdk",
            "forwardAllArgs": false
          }
        ]
      }
    },
    "deploy-sample-apps": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "gh workflow run 'Deploy React Sample Apps'",
            "forwardAllArgs": false
          }
        ],
        "parallel": false
      }
    },
    "enrich-changelog": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node scripts/enrich-dependency-changelogs.mts --package @stream-io/video-react-sdk --notes-out packages/react-sdk/.release-notes.md",
            "forwardAllArgs": false
          }
        ]
      }
    }
  }
}
